# SOUP pins for the reproducible sandbox guest-image build (MGIT-30, FR-17.31).
#
# Every external input is pinned by a content digest (image @sha256, tarball
# sha256) and every non-deterministic build input is fixed (clock, build
# user/host, filesystem UUID). The build VERIFIES against these pins and fails
# LOUD on drift, so a mirror or base-image swap can never silently produce a
# different kernel or rootfs. Output digests are recorded in *_SHA256 after a
# reproducible build so a re-build (or CI) can assert bit-for-bit equality.
#
# Sourced by the build scripts; keep it plain KEY=VALUE (no expansion needed).

# --- Reproducible-build determinism knobs ------------------------------------
# Fixed clock: 2026-07-21T00:00:00Z. Feeds SOURCE_DATE_EPOCH, the kernel
# KBUILD_BUILD_TIMESTAMP, and the ext4 superblock/inode timestamps.
SOURCE_DATE_EPOCH=1784592000
KBUILD_BUILD_USER=mgit
KBUILD_BUILD_HOST=sandbox-image
# Fixed ext4 filesystem UUID ("mgit" + zeros): a random UUID would defeat
# rootfs reproducibility.
ROOTFS_UUID=6d676974-0000-4000-8000-000000000001

# --- Pinned toolchain (by image digest) --------------------------------------
# The builder base and busybox are pinned by digest so the compiler/libc and
# the guest shell are byte-identical across machines and over time.
BUILDER_IMAGE=debian@sha256:7b140f374b289a7c2befc338f42ebe6441b7ea838a042bbd5acbfca6ec875818
BUSYBOX_IMAGE=busybox@sha256:8635836765b0c4c43970660219739baa58b0883c2e429e4b8918f7dd1519455c

# --- vz (Apple Virtualization.framework) kernel: BUILT from source -----------
# Apple's Virtualization.framework presents virtio over PCI, so the guest
# kernel needs VIRTIO_PCI/BLK/CONSOLE/NET/VSOCKETS/FS + FUSE + OVERLAY + EXT4
# + PCI_HOST_GENERIC built in (see vz-kernel.config). The firecracker aarch64
# kernel is virtio-MMIO-only and does NOT work under vz.
#
# Source durability note: kernel.org rotates point releases off its mirrors
# over months. The sha256 pin makes a rotation fail LOUD (not silently wrong);
# for long-term reproducibility, vendor the tarball (VZ_KERNEL_SRC=<path>) — the
# published image bundle (MGIT-61.2) is the durable artifact regardless.
VZ_KERNEL_VERSION=6.12.74
VZ_KERNEL_URL=https://mirrors.edge.kernel.org/pub/linux/kernel/v6.x/linux-6.12.74.tar.xz
VZ_KERNEL_SHA256=3b56eeb1dc9a437f189ca56b823be3769994f59a4ea0895b08ec0d20acaca13e
# Recorded after the first reproducible build (build-kernel-vz.sh asserts it):
VZ_KERNEL_IMAGE_SHA256=e56aacd1dea0a57135fb57f3f43c77f15dbea0a6afe352994b25b4d19bc56d84

# --- firecracker (Linux/KVM) kernel: VENDORED (pin URL + sha256) -------------
# The firecracker backend uses a firecracker-compatible vmlinux. v1 vendors a
# pinned prebuilt per arch (documented in README.md); recorded here once pinned.
FC_KERNEL_AMD64_URL=
FC_KERNEL_AMD64_SHA256=
FC_KERNEL_ARM64_URL=
FC_KERNEL_ARM64_SHA256=
